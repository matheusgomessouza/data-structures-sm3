{
  "name": "typescript-node-dsa",
  "version": "1.0.0",
  "private": true,
  "description": "Professional Node.js + TypeScript workspace for advanced Data Structures and Algorithms study.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --enable-source-maps dist/index.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD --verbose"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@eslint/js": "^9.22.0",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "tsx": "3.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.9"
  }
}
